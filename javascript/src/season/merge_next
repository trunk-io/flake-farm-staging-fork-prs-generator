#!/usr/bin/env python3

import json
import subprocess
import sys

UPSTREAM_REPO = "trunk-io/flake-farm-staging-fork-prs"
FORK_REPO_NAME = "flake-farm-staging-fork-prs-generator"

labels = ["rabbit", "duck"]

pr_number = None
for lbl in labels:
    command = [
        "gh",
        "pr",
        "list",
        "--repo",
        UPSTREAM_REPO,
        "--label",
        lbl,
        "--json",
        "number,headRepository",
        "--state",
        "open",
    ]
    process = subprocess.run(
        command,
        check=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        universal_newlines=True,
    )

    data = json.loads(process.stdout)
    for pr in data:
        head_repo = pr.get("headRepository") or {}
        if head_repo.get("name") == FORK_REPO_NAME:
            pr_number = pr["number"]
            break

    if pr_number is not None:
        break

if pr_number is None:
    print("No open fork PR found with label duck or rabbit")
    sys.exit(0)

merge_command = [
    "gh",
    "pr",
    "merge",
    str(pr_number),
    "--repo",
    UPSTREAM_REPO,
    "--merge",
]
merge_process = subprocess.run(
    merge_command,
    check=True,
    stdout=subprocess.PIPE,
    stderr=subprocess.PIPE,
    universal_newlines=True,
)

if merge_process.returncode == 0:
    print(f"Merged pull request number {pr_number}")
else:
    print(f"Failed to merge pull request number {pr_number}")
    print(f"Error: {merge_process.stderr}")
    sys.exit(1)
